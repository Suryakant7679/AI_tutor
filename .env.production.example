# Copy to .env.production and replace every CHANGE_ME value before deployment.
AIOS_ENV_FILE=.env.production
AIOS_IMAGE=aios:latest
AIOS_HOST=0.0.0.0
AIOS_PORT=8000
HTTP_PORT=80
HTTPS_PORT=443

POSTGRES_USER=aios
POSTGRES_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
POSTGRES_DB=aios
DATABASE_URL=postgresql://aios:CHANGE_ME_DATABASE_PASSWORD@postgres:5432/aios
AIOS_STORAGE_BACKEND=postgres
AIOS_MEMORY_FILE=data/memory.json

REDIS_URL=redis://redis:6379/0
AIOS_REDIS_NAMESPACE=aios
AIOS_REDIS_SESSION_TTL=86400
AIOS_REDIS_CACHE_TTL=300
AIOS_REDIS_STREAM_TTL=3600
AIOS_REDIS_QUEUE_TTL=86400
AIOS_REDIS_MEMORY_TTL=7200

QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=aios_embeddings
QDRANT_API_KEY=
AIOS_VECTOR_BACKEND=qdrant

AIOS_AUTH_REQUIRED=true
AIOS_ADMIN_EMAILS=CHANGE_ME_ADMIN_EMAIL
AIOS_JWT_SECRET=CHANGE_ME_AT_LEAST_32_RANDOM_BYTES
AIOS_JWT_ISSUER=aios
AIOS_JWT_AUDIENCE=aios-api
AIOS_JWT_TTL=3600
AIOS_API_RATE_LIMIT=120
AIOS_API_RATE_WINDOW=60
AIOS_CHAT_RATE_LIMIT=30
AIOS_CHAT_RATE_WINDOW=60

AIOS_UPLOAD_DIR=data/uploads
AIOS_UPLOAD_INDEX=data/uploads.json
AIOS_MAX_UPLOAD_BYTES=10485760
AIOS_PDF_OCR_MAX_PAGES=20
AIOS_PDF_OCR_DPI=200
AIOS_MAX_API_BODY_BYTES=1048576
AIOS_BACKUP_DIR=data/backups
AIOS_BACKUP_RETENTION=7
AIOS_WORKER_STATE_DIR=data/worker_state
AIOS_OBSERVABILITY_FILE=data/observability.json
AIOS_OBSERVABILITY_MAX_EVENTS=10000
AIOS_MONITOR_ROOT=/app
AIOS_FILE_MONITOR_MAX_FILES=50000

AIOS_SCHEDULE_GIT_SECONDS=30
AIOS_SCHEDULE_FILES_SECONDS=60
AIOS_SCHEDULE_CACHE_SECONDS=300
AIOS_SCHEDULE_ANALYTICS_SECONDS=300
AIOS_SCHEDULE_HEALTH_SECONDS=60
AIOS_SCHEDULE_BACKUP_SECONDS=86400
AIOS_SCHEDULE_VECTOR_SECONDS=900

AIOS_PROVIDER=auto
AIOS_DEFAULT_MODEL=
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
AIOS_GROQ_MODEL=llama-3.1-8b-instant
AIOS_GEMINI_MODEL=gemini-2.0-flash
AIOS_OPENAI_MODEL=gpt-4o-mini
AIOS_DEEPSEEK_MODEL=deepseek-chat
AIOS_TEMPERATURE=0.7
AIOS_LLM_TIMEOUT=60
AIOS_LLM_RETRIES=2
AIOS_OPENAI_INPUT_COST_PER_MILLION=0
AIOS_OPENAI_OUTPUT_COST_PER_MILLION=0
AIOS_GROQ_INPUT_COST_PER_MILLION=0
AIOS_GROQ_OUTPUT_COST_PER_MILLION=0
AIOS_GEMINI_INPUT_COST_PER_MILLION=0
AIOS_GEMINI_OUTPUT_COST_PER_MILLION=0
AIOS_DEEPSEEK_INPUT_COST_PER_MILLION=0
AIOS_DEEPSEEK_OUTPUT_COST_PER_MILLION=0

AIOS_HEALTH_ALERT_EMAIL=
AIOS_SMTP_HOST=
AIOS_SMTP_PORT=587
AIOS_SMTP_USERNAME=
AIOS_SMTP_PASSWORD=
AIOS_SMTP_FROM=
AIOS_SMTP_STARTTLS=true
AIOS_SMTP_SSL=false
AIOS_SMTP_TIMEOUT=20

# Optional: create a remotely managed Cloudflare Tunnel and paste its token,
# then start Compose with --profile tunnel.
TUNNEL_TOKEN=
