AIOS_HOST=127.0.0.1
AIOS_PORT=8000
AIOS_DATA_FILE=data/conversations.json
AIOS_STORAGE_BACKEND=auto
AIOS_MEMORY_FILE=data/memory.json
# Auto uses PostgreSQL when DATABASE_URL is set; use json to force local storage.
DATABASE_URL=postgresql://aios:change_me@127.0.0.1:5432/aios
REDIS_URL=redis://127.0.0.1:6379/0
AIOS_REDIS_NAMESPACE=aios
AIOS_REDIS_SESSION_TTL=86400
AIOS_REDIS_CACHE_TTL=300
AIOS_REDIS_STREAM_TTL=3600
AIOS_REDIS_QUEUE_TTL=86400
AIOS_REDIS_MEMORY_TTL=7200
AIOS_CHAT_RATE_LIMIT=30
AIOS_CHAT_RATE_WINDOW=60
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=aios_embeddings
AIOS_VECTOR_BACKEND=auto
AIOS_MCP_WORKSPACE_ROOT=
AIOS_MCP_FILESYSTEM_WRITE=false
AIOS_MCP_TERMINAL_COMMANDS=
AIOS_MCP_REST_HOSTS=
AIOS_MCP_REST_WRITE=false
AIOS_MCP_IMAGE_WRITE=false
AIOS_MCP_CUSTOM_CONFIG=mcp-servers.json
AIOS_MCP_CUSTOM_ENABLED=false
AIOS_MCP_CUSTOM_COMMANDS=python,node,npx,uvx
AIOS_OCR_COMMAND=
AIOS_PDF_OCR_COMMAND=
SLACK_BOT_TOKEN=
NOTION_TOKEN=
GITHUB_TOKEN=
AIOS_SQLITE_PATH=data/aios.db
AIOS_PROVIDER=auto
AIOS_DEFAULT_MODEL=
AIOS_GROQ_MODEL=llama-3.1-8b-instant
AIOS_GEMINI_MODEL=gemini-2.0-flash
AIOS_OPENAI_MODEL=gpt-4o-mini
AIOS_DEEPSEEK_MODEL=deepseek-chat
AIOS_TEMPERATURE=0.7
AIOS_LLM_TIMEOUT=60
AIOS_LLM_RETRIES=2
AIOS_USAGE_FILE=data/llm_usage.json
# Optional comma-separated validator class names. All validators are enabled by default.
AIOS_ENABLED_VALIDATORS=
AIOS_DISABLED_VALIDATORS=
# Optional task routes: coding, reasoning, vision, math, research, general.
# AIOS_CODING_PROVIDER=groq
# AIOS_CODING_GROQ_MODEL=llama-3.1-8b-instant
# Configure current provider prices to enable estimated cost reporting.
AIOS_GROQ_INPUT_COST_PER_MILLION=0
AIOS_GROQ_OUTPUT_COST_PER_MILLION=0
AIOS_UPLOAD_DIR=data/uploads
AIOS_UPLOAD_INDEX=data/uploads.json
AIOS_MAX_UPLOAD_BYTES=10485760

# Add whichever providers you plan to use.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=

# Optional local model settings for later.
OLLAMA_BASE_URL=http://127.0.0.1:11434
